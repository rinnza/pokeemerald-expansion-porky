FuchsiaCity_SafariZone_Office_Text_WardenIsVeryKnowledgeable::
# 28 "data/maps/FuchsiaCity_SafariZone_Office_Frlg/scripts.pory"
	.string "WARDEN SLOWPOKE is very\n"
# 29 "data/maps/FuchsiaCity_SafariZone_Office_Frlg/scripts.pory"
	.string "knowledgeable about POKéMON.\p"
# 30 "data/maps/FuchsiaCity_SafariZone_Office_Frlg/scripts.pory"
	.string "He even has some fossils of rare,\n"
# 31 "data/maps/FuchsiaCity_SafariZone_Office_Frlg/scripts.pory"
