FuchsiaCity_SafariZone_Office_Text_NicknamedWardenSlowpoke::
# 22 "data/maps/FuchsiaCity_SafariZone_Office_Frlg/scripts.pory"
	.string "We nicknamed the WARDEN\n"
# 23 "data/maps/FuchsiaCity_SafariZone_Office_Frlg/scripts.pory"
	.string "“SLOWPOKE.”\p"
# 24 "data/maps/FuchsiaCity_SafariZone_Office_Frlg/scripts.pory"
	.string "You know, he has that vacant look\n"
# 25 "data/maps/FuchsiaCity_SafariZone_Office_Frlg/scripts.pory"
	.string "like a SLOWPOKE.$"
# 26 "data/maps/FuchsiaCity_SafariZone_Office_Frlg/scripts.pory"

